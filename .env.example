# TaiYiYuan (太医院) — Environment Configuration
#
# Copy this file to .env and edit as needed.
# All variables are optional — defaults work for standard clone layouts.

# Database location (default: <repo>/data/taiyiyuan.db)
# TAIYIYUAN_DB=~/longevity-os/data/taiyiyuan.db

# Data root directory (default: repo root)
# LONGEVITY_DATA_DIR=~/longevity-os

# Plot output directory (default: <repo>/plots/)
# LONGEVITY_PLOTS_DIR=~/longevity-os/plots

# USDA FoodData Central API key (free, for nutrition lookups)
# Get yours at: https://fdc.nal.usda.gov/api-key-signup.html
# USDA_API_KEY=your_key_here

# Brave Search API key (optional, for company/job search)
# BRAVE_SEARCH_API_KEY=your_key_here
